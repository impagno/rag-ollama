<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>rag_ollama</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <ItemGroup>
    <!-- PDF processing library -->
    <PackageReference Include="PdfPig" Version="0.1.14" />
    <!-- SQLite database library (Microsoft.Data.Sqlite recommended for .NET 5+) -->
    <PackageReference Include="Microsoft.Data.Sqlite" Version="8.0.0" />
    <PackageReference Include="OllamaSharp" Version="5.2.2" />
  </ItemGroup>
</Project>
